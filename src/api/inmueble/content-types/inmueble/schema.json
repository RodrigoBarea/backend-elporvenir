{
  "kind": "collectionType",
  "collectionName": "inmuebles",
  "info": {
    "singularName": "inmueble",
    "pluralName": "inmuebles",
    "displayName": "Inmueble",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "inmuebleName": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "inmuebleName"
    },
    "Direccion": {
      "type": "text"
    },
    "imagenes": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "terreno": {
      "type": "float"
    },
    "construccion": {
      "type": "float"
    },
    "dormitorios": {
      "type": "integer"
    },
    "banos": {
      "type": "integer"
    },
    "estacionamientos": {
      "type": "integer"
    },
"descripcion": {
  "type": "blocks",
  "required": true
},
"tipo": {
  "type": "enumeration",
  "enum": [
    "Lote",
    "Casa",
    "Departamento",
    "Terreno",
    "Tienda Comercial"
  ],
  "required": true
},
"precio": {
  "type": "decimal",
  "precision": 14,
  "scale": 2,
  "required": true
},
"ubicacion": {
  "type": "customField",
  "customField": "plugin::map-field.map",
  "required": true
},
"active": {
  "type": "boolean",
  "default": true,
  "required": true
},
"isFeatured": {
  "type": "boolean",
  "default": false,
  "required": true
},
"categoria": {
  "type": "relation",
  "relation": "oneToOne",
  "target": "api::categoria.categoria",
  "required": true
},
"agente": {
  "type": "relation",
  "relation": "oneToOne",
  "target": "api::agente.agente",
  "required": true
},
"ciudad": {
  "type": "enumeration",
  "enum": [
    "Tarija",
    "Santa Cruz",
    "La Paz",
    "Cochabamba",
    "Bermejo",
    "Yacuiba"
  ],
  "required": true
},
"frente": {
  "type": "float"
}
  }
}
